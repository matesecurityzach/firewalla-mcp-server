# Firewalla MCP Server — environment configuration
# Copy this file to .env and fill in your actual credentials.

# ─── Required: MSP API credentials ──────────────────────────────────────────

# MSP API access token.
# Get this from your MSP portal: Account Settings → API Settings →
# Generate Personal Access Token.
FIREWALLA_MSP_TOKEN=your_msp_access_token_here

# MSP domain, without the scheme. Example: yourdomain.firewalla.net
FIREWALLA_MSP_ID=yourdomain.firewalla.net

# ─── Optional: scoping ──────────────────────────────────────────────────────

# Restrict all calls to a single box GID. If unset, calls span every box
# the token can see. Retrieve box GIDs via the get_boxes tool.
# FIREWALLA_BOX_ID=00000000-0000-0000-0000-000000000000

# Fallback box GID used by convenience wrappers when none is supplied
# explicitly to a tool call.
# FIREWALLA_DEFAULT_BOX_ID=00000000-0000-0000-0000-000000000000

# ─── Optional: client tuning ────────────────────────────────────────────────

# Request timeout, milliseconds. Range 1000–300000. Default 30000.
# API_TIMEOUT=30000

# MSP requests per minute. Range 1–1000. Default 100. The MSP API itself
# enforces ~100 req/min — raising this past 100 will just trip server-side
# rate limiting.
# API_RATE_LIMIT=100

# Response cache TTL, seconds. Range 0–3600. Default 300. Set to 0 to
# disable caching.
# CACHE_TTL=300

# Default and maximum page sizes for paginated tools.
# DEFAULT_PAGE_SIZE: 1–10000, default 100.
# MAX_PAGE_SIZE: 100–100000, default 10000.
# DEFAULT_PAGE_SIZE=100
# MAX_PAGE_SIZE=10000

# ─── Optional: transport ────────────────────────────────────────────────────

# Transport type: 'stdio' (default, for Claude Desktop / Claude Code) or
# 'http' (Streamable HTTP, for Docker / orchestrators).
# MCP_TRANSPORT=stdio

# HTTP transport settings (only used when MCP_TRANSPORT=http).
# MCP_HTTP_PORT=3000
# MCP_HTTP_PATH=/mcp

# Bind address for the HTTP transport. Defaults to 127.0.0.1 (loopback only)
# so the server is not exposed on every interface. Set to 0.0.0.0 only if
# you have intentionally placed the server behind an authenticated proxy.
# MCP_HTTP_HOST=127.0.0.1

# Additional Host-header values to allow, comma-separated. 'localhost',
# '127.0.0.1', the configured MCP_HTTP_HOST, and their :PORT variants are
# always allowed. Add the public hostname here if you front the server
# with a reverse proxy.
# MCP_HTTP_ALLOWED_HOSTS=mcp.example.com

# CORS Origin allowlist, comma-separated. Empty (default) means only
# same-origin or no-Origin requests are accepted.
# MCP_HTTP_ALLOWED_ORIGINS=https://app.example.com

# Required bearer token for the HTTP transport. When set, every request
# must send 'Authorization: Bearer <token>'. Strongly recommended whenever
# MCP_HTTP_HOST is not loopback.
# MCP_HTTP_BEARER=replace-with-a-long-random-string

# ─── Optional: test / debug ─────────────────────────────────────────────────

# Start with dummy credentials so the process boots without contacting the
# MSP API — used for Docker health checks. Refused when NODE_ENV=production.
# MCP_TEST_MODE=false

# Debug namespaces. Only 'mcp:*' is wired up today; the others listed in
# docs are aspirational — verify in src/monitoring/logger.ts before relying
# on them.
# DEBUG=mcp:*
